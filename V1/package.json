{
  "name": "navex-irm-mcp-server",
  "version": "0.1.0",
  "description": "MCP server + REST facade for the NAVEX IRM Platform API (Power Platform / Copilot Studio ready)",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
